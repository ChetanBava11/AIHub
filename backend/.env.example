# PostgreSQL connection string for the main application database.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_business_ops
# Dedicated database URL for automated tests.
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_business_ops_test
# MongoDB connection string reserved for later phases.
MONGO_URL=mongodb://localhost:27017/ai_business_ops
# Secret used to sign short-lived JWT access tokens.
JWT_SECRET=replace-with-a-long-random-secret
# Google OAuth client id for the backend callback flow.
GOOGLE_CLIENT_ID=your-google-client-id
# Google OAuth client secret paired with the client id above.
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Exact redirect URI registered in Google Cloud for /auth/google/callback.
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback
# Frontend origin allowed by CORS and used for post-login redirects.
FRONTEND_URL=http://localhost:3000
# Secret used by cookie-parser to sign the PKCE verifier cookie.
COOKIE_SECRET=replace-with-a-separate-long-random-secret
# Port used by the Express API server.
PORT=4000
# Runtime mode; use test when running Jest.
NODE_ENV=development
