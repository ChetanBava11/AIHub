# PostgreSQL connection string for the isolated test database.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_business_ops_test
# MongoDB connection string for test runs.
MONGO_URL=mongodb://localhost:27017/ai_business_ops_test
# Secret used by test JWT signing.
JWT_SECRET=test-jwt-secret
# Test Google OAuth client id placeholder.
GOOGLE_CLIENT_ID=test-google-client-id
# Test Google OAuth client secret placeholder.
GOOGLE_CLIENT_SECRET=test-google-client-secret
# Test redirect URI placeholder.
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback
# Allowed frontend origin used by integration tests.
FRONTEND_URL=http://localhost:3000
# Secret used to sign test cookies.
COOKIE_SECRET=test-cookie-secret
# Port used by the API under test.
PORT=4000
# Runtime mode for Jest.
NODE_ENV=test
